build tests/mediator_tests tests/mediator_tests[1]_tests.cmake | ${cmake_ninja_workdir}tests/mediator_tests[1]_tests.cmake: CXX_EXECUTABLE_LINKER__mediator_tests_RelWithDebInfo tests/CMakeFiles/mediator_tests.dir/test_channel.cpp.o tests/CMakeFiles/mediator_tests.dir/test_timer.cpp.o tests/CMakeFiles/mediator_tests.dir/test_reactor.cpp.o tests/CMakeFiles/mediator_tests.dir/test_g711.cpp.o tests/CMakeFiles/mediator_tests.dir/test_watermark.cpp.o tests/CMakeFiles/mediator_tests.dir/test_align.cpp.o tests/CMakeFiles/mediator_tests.dir/test_context_evict.cpp.o tests/CMakeFiles/mediator_tests.dir/test_auth.cpp.o tests/CMakeFiles/mediator_tests.dir/test_heartbeat.cpp.o tests/CMakeFiles/mediator_tests.dir/test_wasm3.cpp.o | libmediator_core.a lib/libgtest_main.a /usr/lib/x86_64-linux-gnu/libspdlog.so.1.9.2 /usr/lib/x86_64-linux-gnu/libfmt.so.8.1.1 libwasm3.a lib/libgtest.a || lib/libgtest.a lib/libgtest_main.a libmediator_core.a libwasm3.a tests/wasm_test_modules
  FLAGS = -O2 -g -DNDEBUG
  LINK_LIBRARIES = libmediator_core.a  lib/libgtest_main.a  /usr/lib/x86_64-linux-gnu/libspdlog.so.1.9.2  /usr/lib/x86_64-linux-gnu/libfmt.so.8.1.1  -Wl,--as-needed  libwasm3.a  -lm  lib/libgtest.a
  OBJECT_DIR = tests/CMakeFiles/mediator_tests.dir
  POST_BUILD = cd /mnt/d/vit/mediator/build-wsl/tests && /usr/bin/cmake -D TEST_TARGET=mediator_tests -D TEST_EXECUTABLE=/mnt/d/vit/mediator/build-wsl/tests/mediator_tests -D TEST_EXECUTOR= -D TEST_WORKING_DIR=/mnt/d/vit/mediator/build-wsl/tests -D TEST_EXTRA_ARGS= -D TEST_PROPERTIES= -D TEST_PREFIX= -D TEST_SUFFIX= -D TEST_FILTER= -D NO_PRETTY_TYPES=FALSE -D NO_PRETTY_VALUES=FALSE -D TEST_LIST=mediator_tests_TESTS -D CTEST_FILE=/mnt/d/vit/mediator/build-wsl/tests/mediator_tests[1]_tests.cmake -D TEST_DISCOVERY_TIMEOUT=5 -D TEST_XML_OUTPUT_DIR= -P /usr/share/cmake-3.22/Modules/GoogleTestAddTests.cmake
  PRE_LINK = :
  RESTAT = 1
  TARGET_FILE = tests/mediator_tests
  TARGET_PDB = mediator_tests.dbg


#############################################
# Utility command for test

build tests/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /mnt/d/vit/mediator/build-wsl/tests && /usr/bin/ctest --force-new-ctest-process
  DESC = Running tests...
  pool = console
  restat = 1

build tests/test: phony tests/CMakeFiles/test.util


